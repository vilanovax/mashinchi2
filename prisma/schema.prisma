generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Cars ───────────────────────────────────────────

model Car {
  id          String   @id @default(cuid())
  nameEn      String
  nameFa      String
  brand       String
  brandFa     String
  category    String   // sedan, suv, hatchback, crossover, pickup
  year        Int      // model year range start
  priceMin    BigInt   // min price in Toman
  priceMax    BigInt   // max price in Toman
  imageUrl    String?
  isNew       Boolean  @default(true) // new (zero-km) or used
  origin      String   // iranian, chinese, korean, japanese, european
  description String?  // short Persian description

  scores      CarScores?
  specs       CarSpecs?
  tags        CarTag[]
  intel       CarIntelligence?
  interactions UserInteraction[]
  reviews     CarReview[]
  prices      PriceHistory[]
  sources     CarSource[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CarScores {
  id              String @id @default(cuid())
  carId           String @unique
  car             Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  comfort         Int    @default(5) // 1-10
  performance     Int    @default(5)
  economy         Int    @default(5) // fuel + maintenance cost
  safety          Int    @default(5)
  prestige        Int    @default(5)
  reliability     Int    @default(5)
  resaleValue     Int    @default(5) // liquidity
  familyFriendly  Int    @default(5)
  sportiness      Int    @default(5)
  offroad         Int    @default(5)
  cityDriving     Int    @default(5)
  longTrip        Int    @default(5)
  maintenanceRisk Int    @default(5) // higher = more risk
  afterSales      Int    @default(5) // dealer/service quality
}

model CarSpecs {
  id            String  @id @default(cuid())
  carId         String  @unique
  car           Car     @relation(fields: [carId], references: [id], onDelete: Cascade)

  engine        String? // e.g. "1.5L Turbo"
  horsepower    Int?
  torque        Int?
  transmission  String? // manual, automatic, CVT
  fuelType      String? // gasoline, diesel, hybrid, electric
  fuelConsumption Float? // liters per 100km
  acceleration  Float?  // 0-100 km/h seconds
  trunkVolume   Int?    // liters
  groundClearance Int?  // mm
  length        Int?    // mm
  width         Int?    // mm
  weight        Int?    // kg
  seatingCapacity Int   @default(5)
}

model CarTag {
  id    String @id @default(cuid())
  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
  tag   String // e.g. "خانوادگی", "اسپرت", "کم‌مصرف", "بادوام"

  @@unique([carId, tag])
}

model CarIntelligence {
  id                String @id @default(cuid())
  carId             String @unique
  car               Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  // Core scores (1-10)
  acceleration      Int    @default(5)
  depreciation      Int    @default(5) // wear & tear rate
  repairCost        Int    @default(5) // 10 = very expensive
  secondHandMarket  Int    @default(5) // liquidity in used market
  priceDropRate     Int    @default(5) // how fast it loses value
  buildQuality      Int    @default(5)
  afterSalesService Int    @default(5)
  ownerSatisfaction Int    @default(5)
  purchaseRisk      Int    @default(5) // 10 = very risky
  fuelEconomy       Int    @default(5)

  // Suitability scores (1-10)
  suitFamily        Int    @default(5)
  suitCity          Int    @default(5)
  suitTravel        Int    @default(5)
  suitYoung         Int    @default(5)
  suitInvestment    Int    @default(5)

  // Rich text data (Farsi)
  frequentPros      String[]  // نقاط قوت پرتکرار
  frequentCons      String[]  // نقاط ضعف پرتکرار
  commonIssues      String[]  // خرابی‌های رایج
  purchaseWarnings  String[]  // هشدارهای خرید
  ownerVerdict      String    // توصیف رایج مالکان
  overallSummary    String    // جمع‌بندی هوشمند
  whyBuy            String    // چرا بخری
  whyNotBuy         String    // چرا نخری
}

model CarReview {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  source    String   // "bama", "blog", "user", "expert"
  summary   String   // AI-generated summary
  pros      String[] // list of pros
  cons      String[] // list of cons
  warnings  String[] // important warnings
  rating    Float?   // 1-5
  createdAt DateTime @default(now())
}

model PriceHistory {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  price     BigInt   // price in Toman
  date      DateTime
  source    String   // "bama", "divar", "manual"
  createdAt DateTime @default(now())

  @@index([carId, date])
}

// ─── Users & Taste ──────────────────────────────────

model User {
  id           String   @id @default(cuid())
  sessionId    String   @unique // cookie-based session
  budget       BigInt?  // user's budget in Toman
  interactions UserInteraction[]
  tasteProfile UserTasteProfile?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserInteraction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  action    String   // "like", "skip", "compare", "detail_view"
  round     Int      @default(1) // which round of recommendations
  createdAt DateTime @default(now())

  @@index([userId, action])
}

model UserTasteProfile {
  id              String @id @default(cuid())
  userId          String @unique
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Taste vector (calculated from interactions)
  comfort         Float  @default(0)
  performance     Float  @default(0)
  economy         Float  @default(0)
  safety          Float  @default(0)
  prestige        Float  @default(0)
  reliability     Float  @default(0)
  resaleValue     Float  @default(0)
  familyFriendly  Float  @default(0)
  sportiness      Float  @default(0)
  offroad         Float  @default(0)
  cityDriving     Float  @default(0)
  longTrip        Float  @default(0)

  // User type scores (derived from interactions)
  typeEconomic    Float  @default(0) // اقتصادی
  typeFamily      Float  @default(0) // خانوادگی
  typeSport       Float  @default(0) // اسپرت
  typePrestige    Float  @default(0) // پرستیژمحور
  typeSafe        Float  @default(0) // کم‌ریسک
  typeSpecial     Float  @default(0) // خاص‌پسند
  typeOffroad     Float  @default(0) // آفرود
  typeCity        Float  @default(0) // شهری
  typeTravel      Float  @default(0) // سفرمحور
  typeInvestment  Float  @default(0) // سرمایه‌ای

  updatedAt       DateTime @updatedAt
}

// ─── Admin / Crawler ────────────────────────────────

model CrawlerConfig {
  id          String   @id @default(cuid())
  name        String   // e.g. "bama_prices", "divar_listings"
  url         String
  type        String   // "price", "review", "listing"
  schedule    String?  // cron expression
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // "create", "update", "delete", "import", "ai_generate"
  entity    String   // "car", "review", "crawler", "price", "settings"
  entityId  String?  // ID of the affected record
  details   String   // JSON string with change details
  adminId   String?  // who performed the action
  createdAt DateTime @default(now())

  @@index([entity, createdAt])
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // hashed
  name      String   // display name
  role      String   @default("editor") // "super_admin", "editor", "viewer"
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CarSource {
  id              String   @id @default(cuid())
  carId           String
  car             Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  // Source info
  type            String   // "comment", "article", "review", "manual"
  sourceSite      String   // "bama", "divar", "zoomit", "charkhan", "blog", "manual"
  url             String?  // link to original page
  title           String?  // title of article/source

  // Raw content
  rawText         String   // raw text (crawled or pasted)

  // AI-processed output
  processedSummary    String?   // AI-generated summary
  extractedPros       String[]  // extracted pros
  extractedCons       String[]  // extracted cons
  extractedIssues     String[]  // common issues found
  extractedWarnings   String[]  // purchase warnings
  extractedScores     String?   // JSON string: { comfort: 7, safety: 8, ... }

  // Status
  status          String   @default("pending") // "pending", "processed", "approved", "rejected"
  appliedAt       DateTime? // when merged into review/intel
  lastCrawledAt   DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([carId, status])
}

model AppSettings {
  key       String   @id         // e.g. "ai_provider", "ai_model", "ai_key_claude"
  value     String
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // "price_change", "new_review", "system"
  title     String
  message   String
  entityId  String?  // related car/review ID
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}
